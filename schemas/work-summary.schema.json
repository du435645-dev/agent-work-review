{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/du435645-dev/agent-work-review/schemas/work-summary.schema.json",
  "title": "Agent Work Review Summary",
  "type": "object",
  "required": ["schema_version", "review_mode", "language", "title", "executive_summary", "based_on_candidates_digest", "outputs", "excluded_candidates"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "review_mode": {"enum": ["phase-review", "self-review", "formal-report"]},
    "language": {"enum": ["en", "zh"]},
    "title": {"type": "string", "minLength": 1},
    "subtitle": {"type": "string"},
    "executive_summary": {"type": "string", "minLength": 1},
    "based_on_candidates_digest": {"type": "string", "minLength": 64, "maxLength": 64},
    "summary_digest": {"type": "string", "minLength": 64, "maxLength": 64},
    "source_agents": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "time_range": {"type": "object"},
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["candidate_ids", "title", "workspace", "evidence_level", "background", "content", "impact", "next_plan", "source_agents", "source_session_ids"],
        "properties": {
          "candidate_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
          "title": {"type": "string", "minLength": 1},
          "workspace": {"type": "string", "minLength": 1},
          "evidence_level": {"enum": ["quantified", "qualified", "progress"]},
          "background": {"type": "string", "minLength": 1},
          "content": {"type": "string", "minLength": 1},
          "impact": {"type": "string", "minLength": 1},
          "next_plan": {"type": "string", "minLength": 1},
          "source_agents": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "source_session_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "excluded_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "reason"],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "additionalProperties": true
}
